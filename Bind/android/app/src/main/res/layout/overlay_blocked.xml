<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlay_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#28282B"
    android:clickable="true"
    android:focusable="true">

    <!-- Scute Text - Top Left Corner (always visible) -->
    <TextView
        android:id="@+id/overlay_scute_logo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="scute"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:fontFamily="@font/plusjakartasans_semibold"
        android:layout_gravity="top|start"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:clickable="false"
        android:focusable="false" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:clickable="false"
        android:focusable="false">

        <!-- Custom overlay image (hidden by default, set programmatically) -->
        <ImageView
            android:id="@+id/overlay_app_icon"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_marginBottom="16dp"
            android:scaleType="centerCrop"
            android:background="@drawable/rounded_overlay_image"
            android:clipToOutline="true"
            android:visibility="gone"
            android:clickable="false"
            android:focusable="false" />

        <!-- Message (e.g. "WhatsApp is blocked.") -->
        <TextView
            android:id="@+id/overlay_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="This app is blocked."
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:fontFamily="@font/plusjakartasans_semibold"
            android:gravity="center"
            android:lineSpacingMultiplier="1.3"
            android:clickable="false"
            android:focusable="false" />

        <!-- Tap to dismiss hint -->
        <TextView
            android:id="@+id/overlay_dismiss_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap anywhere to dismiss"
            android:textColor="#9CA3AF"
            android:textSize="10sp"
            android:fontFamily="@font/plusjakartasans_semibold"
            android:layout_marginTop="24dp"
            android:clickable="false"
            android:focusable="false" />

    </LinearLayout>

</FrameLayout>
